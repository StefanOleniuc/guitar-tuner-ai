# Configurare locală (pentru dezvoltare).
# Pe Railway aceste valori se setează din UI în tab-ul Variables.

ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=DEBUG

# PostgreSQL — pe Railway se injectează automat ca referință
# la plugin-ul Postgres: ${{Postgres.DATABASE_URL}}.
DATABASE_URL=

# SendGrid API key (cont gratuit, 100 emailuri/zi).
# Setezi pe Railway, nu commit-a niciodată valoarea aici.
SENDGRID_API_KEY=

# Secret pentru semnarea token-urilor JWT (orice string lung, random).
GTUNE_JWT_SECRET=schimba-ma-cu-un-secret-random
